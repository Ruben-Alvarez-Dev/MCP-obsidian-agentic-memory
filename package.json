{
  "name": "obsidian-agent-memory",
  "version": "1.0.0",
  "description": "Universal Agent Memory System with Obsidian-compatible storage",
  "author": "Ruben-Alvarez-Dev <ruben.alvarez.dev@gmail.com>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "obsidian-memory": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "benchmark": "tsx src/benchmark.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "obsidian",
    "agent",
    "memory",
    "ai",
    "claude",
    "goose",
    "opencode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ruben-Alvarez-Dev/MCP-obsidian-agentic-memory.git"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "inquirer": "^9.2.0",
    "@types/inquirer": "^9.0.0"
  }
}
